#!/bin/sh

set -eu

cd "$(dirname "$0")/../apps/web"

port="${CONDUCTOR_PORT:-3000}"

if command -v pnpm >/dev/null 2>&1; then
  exec pnpm dev --port "$port"
elif command -v corepack >/dev/null 2>&1; then
  exec corepack pnpm dev --port "$port"
else
  echo "pnpm is required. Install pnpm or enable Corepack for this Node installation." >&2
  exit 1
fi
